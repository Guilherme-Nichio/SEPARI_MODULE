# ───────────────────────────────────────────────────────────────
# Separi — variáveis de ambiente
# Copie este arquivo para ".env" e preencha com os seus valores.
#   cp .env.example .env
# ───────────────────────────────────────────────────────────────

# Supabase (obrigatório) — painel do projeto › Settings › API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# WhatsApp comercial (somente dígitos, com DDI + DDD).
# Opcional — se vazio, usa o número padrão 551938167640.
VITE_WHATSAPP_NUMBER=551938167640
